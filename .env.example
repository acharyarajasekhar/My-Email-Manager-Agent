################################################################################
# accounts.json defines which accounts exist: { "accounts": [{"id": 1}, ...] }
# All credentials use ACCOUNT_N_* prefix — one block per account.
################################################################################

################################################################################
# ACCOUNT 1 CREDENTIALS
# Copy and increment N for each additional account (2, 3, ...)
################################################################################

# Email address for this account (used in Slack labels)
ACCOUNT_1_EMAIL=alice@gmail.com

# Gmail OAuth2 credentials
# Get from Google Cloud Console: https://console.cloud.google.com/
#   Create project → Enable Gmail API → Create OAuth2 credentials (Desktop app)
#   OAuth Playground: https://developers.google.com/oauthplayground
#     Settings → Use your own credentials → Step 1: enter Client ID/Secret
#     Step 2: select https://mail.google.com/ scope → Authorize → Exchange token
ACCOUNT_1_GMAIL_CLIENT_ID=your_client_id_here
ACCOUNT_1_GMAIL_CLIENT_SECRET=your_client_secret_here
ACCOUNT_1_GMAIL_ACCESS_TOKEN=your_access_token_here
ACCOUNT_1_GMAIL_REFRESH_TOKEN=your_refresh_token_here
# ACCOUNT_1_GMAIL_REDIRECT_URL=urn:ietf:wg:oauth:2.0:oob  # optional (this is the default)

# Slack channel ID for this account (where email notifications are posted)
# Format: C0B4RUD32SZ (not #emails-alice)
ACCOUNT_1_SLACK_CHANNEL_ID=C0B4RUD32SZ

# ── Add more accounts as needed ───────────────────────────────────────────────
# ACCOUNT_2_EMAIL=bob@gmail.com
# ACCOUNT_2_GMAIL_CLIENT_ID=
# ACCOUNT_2_GMAIL_CLIENT_SECRET=
# ACCOUNT_2_GMAIL_ACCESS_TOKEN=
# ACCOUNT_2_GMAIL_REFRESH_TOKEN=
# ACCOUNT_2_SLACK_CHANNEL_ID=C1234567890

################################################################################
# SLACK APP SETTINGS (global — apply to all accounts)
################################################################################

# Bot User OAuth Token for posting/updating messages
# https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
# Required scopes: chat:write, channels:history, chat:manage
SLACK_BOT_TOKEN=xoxb-your_bot_token_here

# Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=your_signing_secret_here

################################################################################
# TIMEZONE SETTINGS
################################################################################

# Timezone for all date/time formatting in messages and logs
# Default: Asia/Kolkata (IST - Indian Standard Time)
# Other examples: America/New_York, Europe/London, Australia/Sydney
# Full IANA list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Kolkata

################################################################################
# EMAIL CHECK SETTINGS
################################################################################

# Check interval in milliseconds (default: 3 hours)
# 5min=300000  1h=3600000  3h=10800000  6h=21600000  24h=86400000
EMAIL_CHECK_INTERVAL=10800000

################################################################################
# SUMMARIZER ENGINE
################################################################################

# 'natural' (default): lightweight snippet-based summary, no extra dependencies
# 'ollama':  AI-powered summary — requires local Ollama server (https://ollama.ai)
SUMMARIZER_ENGINE=natural

# Ollama settings (only used when SUMMARIZER_ENGINE=ollama)
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

################################################################################
# SLACK INTERACTIVE FEATURES (local server / server.js)
################################################################################

# Show Delete / Mark as Read / Dismiss buttons in Slack messages
ENABLE_INTERACTIVE_BUTTONS=true

# Where Slack sends button-click events
# Local testing: http://localhost:3000/slack/actions
# ngrok tunnel:  https://YOUR_NGROK_URL.ngrok.io/slack/actions
# CF Worker:     https://email-manager-worker.<subdomain>.workers.dev/slack/actions
SERVER_WEBHOOK_URL=http://localhost:3000/slack/actions

# Port for local webhook server
PORT=3000

################################################################################
# COMMAND LIMITS
################################################################################

# Maximum emails processed in one /email-cleanup run
MAX_EMAILS_PER_CLEANUP=500

# Minimum seconds between /email-reset calls per account (default: 1 hour)
SLACK_COMMAND_COOLDOWN=3600
